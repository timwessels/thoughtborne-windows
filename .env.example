# Thoughtborne — environment variables
#
# Copy this file to `.env` and fill in your API keys and endpoint URLs:
#     cp .env.example .env
#
# `.env` is ignored by git and will never be committed.

# GROQ API Key (Whisper Large V3 Turbo — fast, general-purpose transcription)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# Soniox API Key (de_v2, v4 async REST and Live WebSocket streaming — high accuracy for German)
# Get your key at: https://soniox.com
SONIOX_API_KEY=

# HuggingFace Inference Endpoint (primeline/whisper-large-v3-turbo-german — 2.6% WER for German)
# API key:      https://huggingface.co/settings/tokens
# Endpoint URL: printed after you deploy your own Inference Endpoint
HUGGINGFACE_API_KEY=
HUGGINGFACE_ENDPOINT_URL=

# Modal Parakeet-primeline endpoint (German STT, 4.11% WER on Tuda-De)
# URL is printed after running: modal deploy modal_parakeet/deploy.py
MODAL_ENDPOINT_URL=
