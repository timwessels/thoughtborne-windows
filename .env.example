# Thoughtborne — environment variables
#
# Copy this file to `.env` and fill in your API keys and endpoint URLs:
#     cp .env.example .env
#
# `.env` is ignored by git and will never be committed.

# GROQ API Key (Whisper Large V3 Turbo and Large V3 — free-tier transcription: fast / higher accuracy)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# Soniox API Key (de_v2, v4 async REST and Live WebSocket streaming — high accuracy for German)
# Get your key at: https://soniox.com
SONIOX_API_KEY=
